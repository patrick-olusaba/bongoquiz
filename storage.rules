rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // KCSE papers — public read, authenticated admin write
    match /kcsePapers/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null;
    }
    // Powers images — public read, authenticated admin write
    match /powers/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null;
    }
    // Bible Quiz uploads
    match /bibleQuiz/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
    // Bible Quiz uploads
    match /bibleQuiz/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
