rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Players — anyone can read/write their own record (keyed by phone)
    match /players/{phone} {
      allow read, create, update: if true;
    }

    // Questions — public read, authenticated admin can write
    match /questions/{id} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // Leaderboard — public read, writes only via Admin SDK (saveGameSession Cloud Function)
    match /leaderboard/{phone} {
      allow read:             if true;
      allow create, update:   if false;
      allow delete:           if request.auth != null;
    }

    // Game sessions — public read, writes only via Admin SDK (saveGameSession Cloud Function)
    match /gameSessions/{id} {
      allow read:             if true;
      allow create:           if false;
      allow update, delete:   if request.auth != null;
    }

    // Dismissed payments — admin only
    match /dismissedPayments/{id} {
      allow read, write: if request.auth != null;
    }

    // Granted sessions — admin writes, player reads their own (delete handled server-side)
    match /grantedSessions/{phone} {
      allow read:   if true;
      allow delete: if request.auth != null;
      allow write:  if request.auth != null;
    }

    // Admins — no client access
    match /admins/{id} {
      allow read:  if false;
      allow write: if false;
    }


    // Announcements are broadcast by admins and visible to players
    match /announcements/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /adminAudit/{id} {
      allow read, create: if request.auth != null;
      allow update, delete: if false;
    }

    // Daily bonus awards are server-controlled via Cloud Functions
    match /dailyBonusClaims/{id} {
      allow read, write: if false;
    }
    match /dailyBonusState/{phone} {
      allow read, write: if false;
    }

    // Quests and Rewards — admin manages, server tracks progress
    match /quests/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /playerQuests/{id} {
      allow read: if true; // Players can see their own progress if needed
      allow write: if false; // Only via Cloud Functions
    }

    // Achievements — admin manages badges
    match /badges/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Payments — public read (phone-filtered queries from client), server writes via Admin SDK
    match /payments/{id} {
      allow read:  if true;
      allow write: if false;
    }

    // Powers — public read, authenticated admin can write
    match /powers/{id} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // KCSE Papers metadata — public read, authenticated admin can write
    match /kcsePapers/{id} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // ── Bible Quiz ──────────────────────────────────────────────────────────────
    match /bibleQuizQuestions/{id} {
      allow read:  if true;
      allow write: if request.auth != null;
    }
    match /bibleQuizPayments/{id} {
      allow read:  if true;
      allow write: if false;
    }
    match /bibleQuizSessions/{id} {
      allow read:           if true;
      allow create:         if false;
      allow update, delete: if request.auth != null;
    }
    match /bibleQuizLeaderboard/{id} {
      allow read:           if true;
      allow create, update: if false;
      allow delete:         if request.auth != null;
    }
    match /grantedBibleSessions/{phone} {
      allow read:  if true;
      allow write: if request.auth != null;
    }
    match /dismissedBiblePayments/{id} {
      allow read, write: if request.auth != null;
    }

    // ── Math Quiz ───────────────────────────────────────────────────────────────
    match /mathQuizQuestions/{id} {
      allow read:  if true;
      allow write: if request.auth != null;
    }
    match /mathQuizPayments/{id} {
      allow read:  if true;
      allow write: if false;
    }
    match /mathQuizSessions/{id} {
      allow read:           if true;
      allow create:         if false;
      allow update, delete: if request.auth != null;
    }
    match /mathQuizLeaderboard/{id} {
      allow read:           if true;
      allow create, update: if false;
      allow delete:         if request.auth != null;
    }

    // ── General Knowledge Quiz ──────────────────────────────────────────────────
    match /genQuizQuestions/{id} {
      allow read:  if true;
      allow write: if request.auth != null;
    }
    match /genQuizPayments/{id} {
      allow read:  if true;
      allow write: if false;
    }
    match /genQuizSessions/{id} {
      allow read:           if true;
      allow create:         if false;
      allow update, delete: if request.auth != null;
    }
    match /genQuizLeaderboard/{id} {
      allow read:           if true;
      allow create, update: if false;
      allow delete:         if request.auth != null;
    }
    match /grantedGenSessions/{phone} {
      allow read:  if true;
      allow write: if request.auth != null;
    }
    match /dismissedGenPayments/{id} {
      allow read, write: if request.auth != null;
    }

    // ── Street Bongo ─────────────────────────────────────────────────────────────
    match /streetBongoQuestions/{id} {
      allow read:  if true;
      allow write: if request.auth != null;
    }
    match /streetBongoSessions/{id} {
      allow read:           if true;
      allow create:         if true;
      allow update, delete: if request.auth != null;
    }

    // Agents — any authenticated user can read; only own doc can be written
    match /agents/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Support Chat ────────────────────────────────────────────────────────────
    // Anyone can create a chat and read/write their own messages (no auth required)
    match /supportChats/{chatId} {
      allow read, create: if true;
      allow update:       if true;
      match /messages/{msgId} {
        allow read, create: if true;
        allow update: if true;  // admin marks seenByAdmin
        allow delete: if false;
      }
      match /meta/{doc} {
        allow read, write: if true;
      }
    }

    // ── Biology Quiz ────────────────────────────────────────────────────────────
    match /bioQuizQuestions/{id} {
      allow read:  if true;
      allow write: if request.auth != null;
    }
    match /bioQuizPayments/{id} {
      allow read:  if true;
      allow write: if false;
    }
    match /bioQuizSessions/{id} {
      allow read:           if true;
      allow create:         if false;
      allow update, delete: if request.auth != null;
    }
    match /bioQuizLeaderboard/{id} {
      allow read:           if true;
      allow create, update: if false;
      allow delete:         if request.auth != null;
    }
    match /grantedBioSessions/{phone} {
      allow read:  if true;
      allow write: if request.auth != null;
    }
    match /dismissedBioPayments/{id} {
      allow read, write: if request.auth != null;
    }

    // ── Sudoku ─────────────────────────────────────────────────────────────────
    match /sudokuSessions/{id} {
      allow read:           if true;
      allow create:         if false;
      allow update, delete: if request.auth != null;
    }
    match /sudokuLeaderboard/{id} {
      allow read:           if true;
      allow create, update: if false;
      allow delete:         if request.auth != null;
    }
    match /sudokuPayments/{id} {
      allow read:  if true;
      allow write: if false;
    }
    match /grantedSudokuSessions/{phone} {
      allow read, write: if true;
    }
    match /dismissedSudokuPayments/{id} {
      allow read, write: if true;
    }

    // ── Connect Dots ────────────────────────────────────────────────────────────
    match /connectDotsSessions/{id} {
      allow read:           if true;
      allow create:         if false;
      allow update, delete: if request.auth != null;
    }
    match /connectDotsLeaderboard/{id} {
      allow read:           if true;
      allow create, update: if false;
      allow delete:         if request.auth != null;
    }
    match /connectDotsPayments/{id} {
      allow read:  if true;
      allow write: if false;
    }
    match /grantedConnectDotsSessions/{phone} {
      allow read, write: if true;
    }
    match /dismissedConnectDotsPayments/{id} {
      allow read, write: if true;
    }

    // ── Bongo Market ───────────────────────────────────────────────────────────
    match /playerCoinBalances/{phone} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /bongoMarketProducts/{id} {
      allow read:  if true;
      allow write: if request.auth != null;
    }
    match /bongoMarketOrders/{id} {
      allow read:   if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

  }
}
