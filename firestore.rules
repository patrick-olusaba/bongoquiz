rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Players — anyone can create/update their own record (keyed by phone)
    // Only authenticated admin can read
    match /players/{phone} {
      allow create, update: if true;
      allow read:           if request.auth != null;
    }

    // Questions — public read, authenticated admin can write
    match /questions/{id} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // Leaderboard — public read, authenticated admin can write
    match /leaderboard/{id} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // Game sessions — public read (phone-filtered queries from client), authenticated admin can write
    match /gameSessions/{id} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // Admins — no client access
    match /admins/{id} {
      allow read:  if false;
      allow write: if false;
    }

    // Payments — public read (phone-filtered queries from client), server writes via Admin SDK
    match /payments/{id} {
      allow read:  if true;
      allow write: if false;
    }

    // Powers — public read, authenticated admin can write
    match /powers/{id} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // KCSE Papers metadata — public read, authenticated admin can write
    match /kcsePapers/{id} {
      allow read:  if true;
      allow write: if request.auth != null;
    }
  }
}
